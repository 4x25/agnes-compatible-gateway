{
  "nodeModulesDir": "manual",
  "lock": true,
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "test": "deno test --allow-env=DENO_DEPLOYMENT_ID,GITHUB_SHA,CI_COMMIT_SHA,OPENAI_CUSTOM_HEADERS",
    "test:coverage": "deno test --allow-env=DENO_DEPLOYMENT_ID,GITHUB_SHA,CI_COMMIT_SHA,OPENAI_CUSTOM_HEADERS --coverage=coverage && deno coverage coverage",
    "smoke": "deno run --allow-net --allow-env=DENO_DEPLOYMENT_ID,GITHUB_SHA,CI_COMMIT_SHA scripts/live_smoke.ts",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve --allow-env=AGNES_BASE_URL,DENO_DEPLOYMENT_ID,GITHUB_SHA,CI_COMMIT_SHA --allow-net --allow-read _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*",
    "coverage/"
  ],
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.19",
    "fresh": "jsr:@fresh/core@2.3.3",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@1.1.2",
    "openai": "npm:openai@6.45.0",
    "vite": "npm:vite@7.3.6"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "types": [
      "vite/client"
    ]
  }
}
