#!/bin/sh

set -eu

echo "Running Format, lint, and type check..."

if command -v deno >/dev/null 2>&1; then
  DENO_COMMAND=deno
elif [ -x "${DENO_BIN:-}" ]; then
  DENO_COMMAND=$DENO_BIN
elif [ -x "$HOME/.deno/bin/deno" ]; then
  DENO_COMMAND="$HOME/.deno/bin/deno"
else
  echo "Deno is required for commits; install Deno or set DENO_BIN." >&2
  exit 1
fi

"$DENO_COMMAND" task check
