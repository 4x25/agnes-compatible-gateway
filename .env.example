# Optional runtime configuration. Production callers always send their own
# Agnes key in the HTTP Authorization header.
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# Live contract tests only. Both gates are required. Keep the key empty in this
# example and never configure either variable on a production deployment.
RUN_AGNES_LIVE_TESTS=0
AGNES_API_KEY_ONLY_FOR_TEST=

# Existing-deployment acceptance only. `health` is non-billable; selecting
# `all` explicitly performs Chat, image-edit, and video generation as well.
RUN_DEPLOYMENT_LIVE_TESTS=0
DEPLOYMENT_SMOKE_BASE_URL=
DEPLOYMENT_SMOKE_SCOPES=health
